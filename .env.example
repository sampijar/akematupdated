# Akemat Foundation — environment variables
# Isi nilai asli di Vercel Dashboard → Project → Settings → Environment Variables.
# JANGAN commit file .env berisi nilai asli ke git.

# ── Supabase (opsional — tanpa ini, app tetap jalan pakai localStorage) ──
# Jalankan db-schema.sql di Supabase SQL Editor dulu, lalu ambil 3 nilai ini
# dari Settings → API. SUPABASE_ANON_KEY aman diekspos ke browser (lihat
# api/config.js); SUPABASE_SERVICE_KEY TIDAK PERNAH boleh sampai ke frontend.
# Registrasi & forgot-password otomatis pakai Supabase Auth Admin API (user
# dibuat langsung ter-konfirmasi, tidak perlu ubah setting "Confirm email"
# di dashboard Supabase — verifikasinya lewat WA OTP, bukan email).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Kalau kamu connect Supabase lewat Vercel Marketplace integration (auto),
# variabel ini kadang otomatis bernama SUPABASE_SERVICE_ROLE_KEY, bukan
# SUPABASE_SERVICE_KEY — kode kita menerima dua-duanya, jadi tidak perlu
# rename manual, biarkan saja nama apapun yang di-generate otomatis.
SUPABASE_SERVICE_KEY=

# ── Panel Admin (api/admin.js) — review manual verifikasi KTP & campaign ──
# Daftar email (pisah koma) yang boleh buka /#admin. HARUS sama persis
# dengan email akun yang dipakai login di app (bukan role di tabel users —
# supaya tidak ada cara pengguna biasa menaikkan hak akses lewat data yang
# bisa mereka tulis sendiri).
ADMIN_EMAILS=

# ── DOKU Checkout (api/doku-payment.js, api/doku-notify.js) ──
# Client Id & Secret Key: DOKU Back Office → menu Integrasi/API.
# Beda nilai untuk sandbox (sandbox.doku.com) vs production.
DOKU_CLIENT_ID=
DOKU_SECRET_KEY=
DOKU_ENV=sandbox
# DOKU_ENV=production   # ganti setelah selesai testing di sandbox

# ── Fazpass WA OTP (api/fazpass-otp.js, api/auth.js) ──
# Merchant Key: dashboard.fazpass.com → Settings
# Gateway Key: dashboard.fazpass.com → Integration → gateway WA_GENERIC_OTP (Fazpass Generic 7) → Show Key
# FAZPASS_MERCHANT_KEY juga dipakai sebagai kunci penandatanganan bukti OTP
# internal (lib/otpProof.js) — tidak perlu env var terpisah untuk itu.
FAZPASS_MERCHANT_KEY=
FAZPASS_GATEWAY_KEY=

# ── Cron: hapus otomatis foto KTP yang ditolak (api/cron-purge-ktp.js) ──
# String acak bebas (mis. hasil generate password manager) — dipakai Vercel
# untuk memverifikasi bahwa yang memanggil endpoint cron benar-benar Vercel,
# bukan orang lain. Wajib diisi, kalau tidak endpoint-nya menolak semua request.
CRON_SECRET=

# ── Google Analytics (opsional) ──────────────────────────────
# Kosongkan untuk menonaktifkan analytics sepenuhnya (default). Isi dengan
# Measurement ID GA4 (format G-XXXXXXXXXX) dari analytics.google.com untuk
# mengaktifkan tracking kunjungan.
GA_MEASUREMENT_ID=

# ── Push Notification (lib/webPush.js, api/db.js (table push_subscriptions)) ──
# Kosongkan untuk menonaktifkan notifikasi push sepenuhnya (default, tombol
# "Aktifkan Notifikasi" di Profil akan gagal dengan pesan jelas). Sepasang
# kunci sudah di-generate-kan dan dikirim terpisah lewat chat (BUKAN di sini
# — VAPID_PRIVATE_KEY adalah rahasia, tidak boleh ikut ter-commit ke git).
# Mau generate pasangan baru sendiri? npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
