# Akemat Foundation — environment variables
# Isi nilai asli di Netlify Dashboard → Site settings → Environment variables.
# JANGAN commit file .env berisi nilai asli ke git.

# ── Supabase (opsional, lihat db-schema.sql) ────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── iPaymu (netlify/functions/ipaymu-payment.js) ────────────
# VA & API Key: dashboard iPaymu → Integration. Beda nilai untuk Sandbox vs Production.
IPAYMU_VA=
IPAYMU_API_KEY=
IPAYMU_ENV=production
# IPAYMU_ENV=sandbox   # gunakan ini saat masih testing

# ── Fazpass WA OTP (netlify/functions/fazpass-otp.js) ───────
# Merchant Key: dashboard.fazpass.com → Settings
# Gateway Key: dashboard.fazpass.com → Integration → gateway WA_GENERIC_OTP (Fazpass Generic 7) → Show Key
FAZPASS_MERCHANT_KEY=
FAZPASS_GATEWAY_KEY=
